generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth models ────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  role          String        @default("CUSTOMER")
  onboarded     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  entitlements  Entitlement[]
  waitlist      WaitlistEntry[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Studio catalog models ───────────────────────────────────────────────────

model Studio {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  address     String   @default("")
  imageUrl    String?
  coordLat    Float?
  coordLng    Float?
  timezone        String   @default("UTC")
  waitlistEnabled Boolean  @default(true)
  ownerId         String
  createdAt       DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rooms        Room[]
  serviceTypes ServiceType[]
  products     Product[]
  classSessions ClassSession[]
  instructors  StudioInstructor[]
}

model StudioInstructor {
  studioId     String
  instructorId String
  addedAt      DateTime @default(now())

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@id([studioId, instructorId])
  @@index([instructorId])
}

model Room {
  id       String @id @default(cuid())
  studioId String
  name     String
  capacity Int

  studio        Studio         @relation(fields: [studioId], references: [id], onDelete: Cascade)
  classSessions ClassSession[]

  @@index([studioId])
}

model ServiceType {
  id              String @id @default(cuid())
  studioId        String
  name            String
  description     String @default("")
  color           String @default("sage")
  durationMinutes Int

  studio        Studio           @relation(fields: [studioId], references: [id], onDelete: Cascade)
  classSessions ClassSession[]
  templates     SessionTemplate[]

  @@index([studioId])
}

model Product {
  id             String   @id @default(cuid())
  studioId       String
  type           String
  name           String
  description    String   @default("")
  price          Int
  credits        Int?
  sessionCount   Int?
  validDays      Int?
  serviceTypeIds String   @default("[]")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
}

model SessionTemplate {
  id               String   @id @default(cuid())
  studioId         String
  serviceTypeId    String
  roomId           String
  instructorId     String   @default("")
  daysOfWeek       String   @default("[]")
  startTime        String
  capacityOverride Int?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])

  @@index([studioId])
}

model ClassSession {
  id            String   @id @default(cuid())
  studioId      String
  serviceTypeId String
  roomId        String
  instructorId  String   @default("")
  templateId    String?
  date          DateTime
  startTime     String
  endTime       String
  capacity      Int
  bookedCount   Int      @default(0)
  waitlistCount Int      @default(0)
  status        String   @default("SCHEDULED")
  createdAt     DateTime @default(now())

  studio      Studio      @relation(fields: [studioId], references: [id], onDelete: Cascade)
  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])
  room        Room        @relation(fields: [roomId], references: [id])

  @@index([studioId])
  @@index([date])
  @@index([studioId, date])
}

// ── App models ─────────────────────────────────────────────────────────────

model Booking {
  id          String    @id @default(cuid())
  userId      String
  sessionId   String
  status      String    @default("CONFIRMED")
  bookedAt    DateTime  @default(now())
  cancelledAt DateTime?
  chargeId    String    @default("")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
}

model Entitlement {
  id             String    @id @default(cuid())
  userId         String
  type           String
  productId      String
  remaining      Int
  serviceTypeIds String    @default("[]")
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WaitlistEntry {
  id             String    @id @default(cuid())
  userId         String
  sessionId      String
  status         String    @default("WAITING")
  position       Int
  joinedAt       DateTime  @default(now())
  offeredAt      DateTime?
  offerExpiresAt DateTime?
  acceptedAt     DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
}
