# Google Maps
# Create an API key at https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API
# Restrict key to: Maps JavaScript API + your domain/localhost
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here   # generate with: openssl rand -base64 32

# Database (Neon PostgreSQL)
# 1. Go to https://neon.tech and create a free account + project
# 2. From the project dashboard, click "Connect" → copy the connection string
# 3. Paste it here (format: postgresql://user:pass@host/dbname?sslmode=require)
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# Google OAuth
# Create credentials at https://console.developers.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
# Create app at https://developers.facebook.com/apps/
# Authorized redirect URI: http://localhost:3000/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
