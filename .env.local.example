# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here   # generate with: openssl rand -base64 32

# Database (SQLite — no changes needed for local dev)
DATABASE_URL="file:./prisma/dev.db"

# Google OAuth
# Create credentials at https://console.developers.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth
# Create App ID + Service ID at https://developer.apple.com/account/
# Authorized redirect URI: http://localhost:3000/api/auth/callback/apple
APPLE_ID=
APPLE_SECRET=
